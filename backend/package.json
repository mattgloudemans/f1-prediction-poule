{
  "name": "f1-prediction-backend",
  "version": "1.0.0",
  "description": "Backend API for F1 Prediction Poule",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node dist/database/migrate.js",
    "seed": "node dist/database/seed.js",
    "sync:results": "npx ts-node src/scripts/syncRaceResults.ts",
    "results:provisional": "npx ts-node src/scripts/sendProvisionalResults.ts",
    "results:final": "npx ts-node src/scripts/processFinalResults.ts",
    "predictions:copy-missing": "npx ts-node src/scripts/copyMissingPredictions.ts"
  },
  "keywords": ["f1", "formula1", "predictions"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "nodemailer": "^6.9.7",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^6.4.14",
    "@types/multer": "^1.4.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "@types/bcrypt": "^5.0.2",
    "typescript": "^5.3.3",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2"
  }
}

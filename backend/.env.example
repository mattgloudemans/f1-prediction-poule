# Server Configuration
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://f1user:f1password@localhost:5432/f1_predictions

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=F1 Prediction Poule <your-gmail@gmail.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# API Configuration
OPENF1_API_URL=https://api.openf1.org/v1
JOLPI_API_URL=https://api.jolpi.ca/ergast/f1

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Race Lock Time (minutes before race start)
PREDICTION_LOCK_MINUTES=1
